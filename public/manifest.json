{
  "manifest_version": 3,
  "name": "Tweet Face Filter",
  "description": "Hide tweets containing a configured person's face.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "*://x.com/*",
    "*://twitter.com/*",
    "*://pbs.twimg.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tweet Face Filter",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["models/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
