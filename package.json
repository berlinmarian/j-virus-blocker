{
  "name": "j-virus-blocker",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that hides tweets containing a target person's face.",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests scripts vite.config.ts --ext .ts,.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "download-models": "node ./scripts/download-models.mjs"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "face-api.js": "^0.22.2"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.311",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}